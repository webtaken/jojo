#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/jojo"
CONFIG_FILE="$CONFIG_DIR/config"
STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/jojo"
STATE_FILE="$STATE_DIR/state"
DEFAULT_THRESHOLD=80
DEFAULT_DELAY=1
INSTALL_DIR="$HOME/.local/bin"
INSTALL_PATH="$INSTALL_DIR/jojo"

read_config_value() {
  local key="$1" default="$2"
  if [[ -f "$CONFIG_FILE" ]]; then
    local val
    val=$(grep "^$key=" "$CONFIG_FILE" 2>/dev/null | tail -1 | cut -d= -f2- || true)
    if [[ -n "$val" ]]; then
      echo "$val"
      return
    fi
  fi
  echo "$default"
}

get_threshold() {
  if [[ -n "${RAM_THRESHOLD:-}" ]]; then
    echo "$RAM_THRESHOLD"
  else
    read_config_value THRESHOLD "$DEFAULT_THRESHOLD"
  fi
}

get_delay() {
  read_config_value DELAY_MINUTES "$DEFAULT_DELAY"
}

write_config() {
  local key="$1" value="$2"
  local t d
  t=$(read_config_value THRESHOLD "$DEFAULT_THRESHOLD")
  d=$(read_config_value DELAY_MINUTES "$DEFAULT_DELAY")
  case "$key" in
    THRESHOLD)     t="$value" ;;
    DELAY_MINUTES) d="$value" ;;
  esac
  mkdir -p "$CONFIG_DIR"
  {
    printf 'THRESHOLD=%s\n'     "$t"
    printf 'DELAY_MINUTES=%s\n' "$d"
  } > "$CONFIG_FILE"
}

read_usage() {
  awk '/^MemTotal:/     {total=$2}
       /^MemAvailable:/ {avail=$2}
       END              {printf("%d", (total-avail)*100/total)}' /proc/meminfo
}

is_installed() {
  [[ -x "$INSTALL_PATH" ]] && crontab -l 2>/dev/null | grep -qF "$INSTALL_PATH"
}

update_cron() {
  local delay cron_line existing
  delay=$(get_delay)
  if (( delay == 1 )); then
    cron_line="* * * * * $INSTALL_PATH check >/dev/null 2>&1"
  else
    cron_line="*/$delay * * * * $INSTALL_PATH check >/dev/null 2>&1"
  fi
  existing="$(crontab -l 2>/dev/null | grep -vF "$INSTALL_PATH" || true)"
  if [[ -n "$existing" ]]; then
    printf '%s\n%s\n' "$existing" "$cron_line" | crontab -
  else
    printf '%s\n' "$cron_line" | crontab -
  fi
}

cmd_check() {
  local threshold usage prev_state new_state
  threshold=$(get_threshold)

  # notify-send needs these when invoked from cron (no inherited graphical env)
  export DISPLAY="${DISPLAY:-:0}"
  export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/$(id -u)/bus}"

  mkdir -p "$STATE_DIR"
  usage=$(read_usage)

  prev_state="OK"
  [[ -f "$STATE_FILE" ]] && prev_state=$(<"$STATE_FILE")

  if (( usage >= threshold )); then
    new_state="ALERT"
  else
    new_state="OK"
  fi

  if [[ "$new_state" != "$prev_state" ]]; then
    if [[ "$new_state" == "ALERT" ]]; then
      notify-send -u critical "RAM high" "Memory usage at ${usage}% (threshold ${threshold}%)"
    fi
    echo "$new_state" > "$STATE_FILE"
  fi
}

cmd_set() {
  local key="${1:-}" value="${2:-}"
  case "$key" in
    threshold)
      if [[ ! "$value" =~ ^[0-9]+$ ]] || (( value < 1 || value > 99 )); then
        echo "error: threshold must be an integer 1-99" >&2
        exit 1
      fi
      write_config THRESHOLD "$value"
      echo "Threshold set to ${value}%"
      ;;
    delay)
      if [[ ! "$value" =~ ^[0-9]+$ ]] || (( value < 1 || value > 59 )); then
        echo "error: delay must be an integer 1-59 (minutes)" >&2
        exit 1
      fi
      write_config DELAY_MINUTES "$value"
      echo "Delay set to ${value} minute(s)."
      if is_installed; then
        update_cron
        echo "Cron entry updated."
      fi
      ;;
    "")
      echo "error: missing key. Use 'jojo set threshold <n>' or 'jojo set delay <n>'" >&2
      exit 1
      ;;
    *)
      echo "error: unknown key '$key'. Valid keys: threshold, delay" >&2
      exit 1
      ;;
  esac
}

cmd_get() {
  local key="${1:-}"
  case "$key" in
    ""|all)
      printf 'threshold: %s%%\ndelay:     %s min\n' "$(get_threshold)" "$(get_delay)"
      ;;
    threshold) printf '%s%%\n' "$(get_threshold)" ;;
    delay)     printf '%s min\n' "$(get_delay)" ;;
    *) echo "error: unknown key '$key'. Valid keys: threshold, delay" >&2; exit 1 ;;
  esac
}

cmd_status() {
  local threshold delay usage state
  threshold=$(get_threshold)
  delay=$(get_delay)
  usage=$(read_usage)
  state="OK"
  [[ -f "$STATE_FILE" ]] && state=$(<"$STATE_FILE")
  printf 'usage:     %s%%\nthreshold: %s%%\ndelay:     %s min\nstate:     %s\n' \
         "$usage" "$threshold" "$delay" "$state"
}

cmd_install() {
  local src
  src="$(readlink -f "$0")"

  mkdir -p "$INSTALL_DIR"

  if [[ "$src" != "$INSTALL_PATH" ]]; then
    cp "$src" "$INSTALL_PATH"
    chmod +x "$INSTALL_PATH"
    echo "Installed: $INSTALL_PATH"
  fi

  update_cron
  echo "Cron entry added (runs every $(get_delay) minute(s))."

  case ":$PATH:" in
    *":$INSTALL_DIR:"*) ;;
    *)
      echo ""
      echo "NOTE: $INSTALL_DIR is not on your PATH."
      echo "Add this line to ~/.bashrc (or ~/.zshrc):"
      echo "  export PATH=\"\$HOME/.local/bin:\$PATH\""
      echo "Then restart your shell or: source ~/.bashrc"
      ;;
  esac

  echo ""
  echo "Done. Try: jojo status"
}

cmd_uninstall() {
  local filtered
  filtered="$(crontab -l 2>/dev/null | grep -vF "$INSTALL_PATH" || true)"
  if [[ -n "$filtered" ]]; then
    printf '%s\n' "$filtered" | crontab -
  else
    crontab -r 2>/dev/null || true
  fi
  rm -f "$INSTALL_PATH"
  rm -f "$STATE_FILE"
  echo "Uninstalled jojo and removed cron entry."
}

cmd_help() {
  cat <<EOF
jojo — RAM threshold monitor with desktop notifications

Usage: jojo [command] [args]

Commands:
  check                    Run the threshold check (default; called by cron)
  set threshold <percent>  Persist threshold (1-99). Example: jojo set threshold 80
  set delay <minutes>      Persist cron interval (1-59). Example: jojo set delay 5
  get [key]                Print a value (threshold|delay) or all if omitted
  status                   Print current usage, threshold, delay, and state
  install                  Install to ~/.local/bin and add cron entry
  uninstall                Remove from ~/.local/bin and remove cron entry
  help                     Show this message

Environment:
  RAM_THRESHOLD            One-off override; takes precedence over the persisted threshold
EOF
}

case "${1:-check}" in
  check)           cmd_check ;;
  set)             shift; cmd_set "${1:-}" "${2:-}" ;;
  get)             shift; cmd_get "${1:-}" ;;
  status)          cmd_status ;;
  install)         cmd_install ;;
  uninstall)       cmd_uninstall ;;
  help|-h|--help)  cmd_help ;;
  *) echo "unknown command: $1" >&2; echo "" >&2; cmd_help >&2; exit 1 ;;
esac
