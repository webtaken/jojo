#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/jojo"
CONFIG_FILE="$CONFIG_DIR/config"
STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/jojo"
STATE_FILE="$STATE_DIR/state"
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/jojo"
SOUND_FILE="fahhh.mp3"
DEFAULT_THRESHOLD=80
DEFAULT_DELAY=1
DEFAULT_BEHAVIOUR="casual"
CASUAL_REPEAT_SECONDS=$((10 * 60))
INSTALL_DIR="$HOME/.local/bin"
INSTALL_PATH="$INSTALL_DIR/jojo"
LAUNCHD_LABEL="com.webtaken.jojo"
LAUNCHD_PLIST="$HOME/Library/LaunchAgents/$LAUNCHD_LABEL.plist"

case "$(uname -s)" in
  Linux)  JOJO_OS="linux" ;;
  Darwin) JOJO_OS="macos" ;;
  *)      echo "error: unsupported OS: $(uname -s)" >&2; exit 1 ;;
esac

# Portable replacement for `readlink -f` (BSD readlink lacks -f on older macOS)
resolve_path() {
  local target="$1" dir link_target
  while [[ -L "$target" ]]; do
    dir="$(cd -P "$(dirname "$target")" && pwd)"
    link_target="$(readlink "$target")"
    if [[ "$link_target" = /* ]]; then
      target="$link_target"
    else
      target="$dir/$link_target"
    fi
  done
  dir="$(cd -P "$(dirname "$target")" && pwd)"
  echo "$dir/$(basename "$target")"
}

read_config_value() {
  local key="$1" default="$2"
  if [[ -f "$CONFIG_FILE" ]]; then
    local val
    val=$(grep "^$key=" "$CONFIG_FILE" 2>/dev/null | tail -1 | cut -d= -f2- || true)
    if [[ -n "$val" ]]; then
      echo "$val"
      return
    fi
  fi
  echo "$default"
}

get_threshold() {
  if [[ -n "${RAM_THRESHOLD:-}" ]]; then
    echo "$RAM_THRESHOLD"
  else
    read_config_value THRESHOLD "$DEFAULT_THRESHOLD"
  fi
}

get_delay() {
  read_config_value DELAY_MINUTES "$DEFAULT_DELAY"
}

get_behaviour() {
  read_config_value BEHAVIOUR "$DEFAULT_BEHAVIOUR"
}

behaviour_emoji() {
  case "$1" in
    annoying) echo "🚨" ;;
    casual)   echo "🙂" ;;
    chill)    echo "😎" ;;
    *)        echo "❓" ;;
  esac
}

write_config() {
  local key="$1" value="$2"
  local t d b
  t=$(read_config_value THRESHOLD "$DEFAULT_THRESHOLD")
  d=$(read_config_value DELAY_MINUTES "$DEFAULT_DELAY")
  b=$(read_config_value BEHAVIOUR "$DEFAULT_BEHAVIOUR")
  case "$key" in
    THRESHOLD)     t="$value" ;;
    DELAY_MINUTES) d="$value" ;;
    BEHAVIOUR)     b="$value" ;;
  esac
  mkdir -p "$CONFIG_DIR"
  {
    printf 'THRESHOLD=%s\n'     "$t"
    printf 'DELAY_MINUTES=%s\n' "$d"
    printf 'BEHAVIOUR=%s\n'     "$b"
  } > "$CONFIG_FILE"
}

read_usage() {
  if [[ "$JOJO_OS" == "linux" ]]; then
    awk '/^MemTotal:/     {total=$2}
         /^MemAvailable:/ {avail=$2}
         END              {printf("%d", (total-avail)*100/total)}' /proc/meminfo
  else
    local total pagesize pages_used
    total=$(sysctl -n hw.memsize)
    pagesize=$(sysctl -n hw.pagesize)
    pages_used=$(vm_stat | awk '
      BEGIN {active=0; wired=0; compressed=0}
      /Pages active:/                 {gsub(/\./,"",$3); active=$3}
      /Pages wired down:/             {gsub(/\./,"",$4); wired=$4}
      /Pages occupied by compressor:/ {gsub(/\./,"",$5); compressed=$5}
      END {print active + wired + compressed}
    ')
    echo $(( pages_used * pagesize * 100 / total ))
  fi
}

send_notification() {
  local usage="$1" threshold="$2"
  if [[ "$JOJO_OS" == "linux" ]]; then
    export DISPLAY="${DISPLAY:-:0}"
    export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/$(id -u)/bus}"
    notify-send -u normal "RAM high" "Memory usage at ${usage}% (threshold ${threshold}%)"
  else
    osascript -e "display notification \"Memory usage at ${usage}% (threshold ${threshold}%)\" with title \"RAM high\""
  fi
}

play_alert_sound() {
  local sound
  for candidate in \
      "$DATA_DIR/$SOUND_FILE" \
      "$(dirname "$(resolve_path "$0")")/$SOUND_FILE"; do
    if [[ -f "$candidate" ]]; then
      sound="$candidate"; break
    fi
  done
  [[ -z "${sound:-}" ]] && return 0

  if [[ "$JOJO_OS" == "linux" ]]; then
    export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
  fi

  if command -v afplay >/dev/null 2>&1; then
    (afplay "$sound" >/dev/null 2>&1 &)
  elif command -v ffplay >/dev/null 2>&1; then
    (ffplay -nodisp -autoexit -loglevel quiet "$sound" >/dev/null 2>&1 &)
  elif command -v mpg123 >/dev/null 2>&1; then
    (mpg123 -q "$sound" >/dev/null 2>&1 &)
  elif command -v paplay >/dev/null 2>&1; then
    (paplay "$sound" >/dev/null 2>&1 &)
  fi
}

scheduler_name() {
  if [[ "$JOJO_OS" == "linux" ]]; then echo "cron"; else echo "launchd"; fi
}

is_installed() {
  if [[ "$JOJO_OS" == "linux" ]]; then
    [[ -x "$INSTALL_PATH" ]] && crontab -l 2>/dev/null | grep -qF "$INSTALL_PATH"
  else
    [[ -x "$INSTALL_PATH" ]] && [[ -f "$LAUNCHD_PLIST" ]]
  fi
}

update_scheduler() {
  local delay
  delay=$(get_delay)

  if [[ "$JOJO_OS" == "linux" ]]; then
    local cron_line existing
    if (( delay == 1 )); then
      cron_line="* * * * * $INSTALL_PATH check >/dev/null 2>&1"
    else
      cron_line="*/$delay * * * * $INSTALL_PATH check >/dev/null 2>&1"
    fi
    existing="$(crontab -l 2>/dev/null | grep -vF "$INSTALL_PATH" || true)"
    if [[ -n "$existing" ]]; then
      printf '%s\n%s\n' "$existing" "$cron_line" | crontab -
    else
      printf '%s\n' "$cron_line" | crontab -
    fi
  else
    local interval=$(( delay * 60 ))
    mkdir -p "$(dirname "$LAUNCHD_PLIST")"
    launchctl unload "$LAUNCHD_PLIST" 2>/dev/null || true
    cat > "$LAUNCHD_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>$LAUNCHD_LABEL</string>
    <key>ProgramArguments</key>
    <array>
        <string>$INSTALL_PATH</string>
        <string>check</string>
    </array>
    <key>StartInterval</key>
    <integer>$interval</integer>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
EOF
    launchctl load "$LAUNCHD_PLIST"
  fi
}

remove_scheduler() {
  if [[ "$JOJO_OS" == "linux" ]]; then
    local filtered
    filtered="$(crontab -l 2>/dev/null | grep -vF "$INSTALL_PATH" || true)"
    if [[ -n "$filtered" ]]; then
      printf '%s\n' "$filtered" | crontab -
    else
      crontab -r 2>/dev/null || true
    fi
  else
    launchctl unload "$LAUNCHD_PLIST" 2>/dev/null || true
    rm -f "$LAUNCHD_PLIST"
  fi
}

cmd_check() {
  local threshold behaviour usage prev_state last_alert new_state now should_notify line
  threshold=$(get_threshold)
  behaviour=$(get_behaviour)
  mkdir -p "$STATE_DIR"
  usage=$(read_usage)
  now=$(date +%s)

  prev_state="OK"
  last_alert=0
  if [[ -f "$STATE_FILE" ]]; then
    { IFS= read -r line && prev_state="$line"
      IFS= read -r line && last_alert="$line"
    } < "$STATE_FILE" || true
  fi
  [[ "$last_alert" =~ ^[0-9]+$ ]] || last_alert=0

  if (( usage >= threshold )); then
    new_state="ALERT"
  else
    new_state="OK"
  fi

  should_notify=0
  if [[ "$new_state" == "ALERT" ]]; then
    if [[ "$prev_state" != "ALERT" ]]; then
      should_notify=1
    else
      case "$behaviour" in
        annoying) should_notify=1 ;;
        casual)
          if (( now - last_alert >= CASUAL_REPEAT_SECONDS )); then
            should_notify=1
          fi
          ;;
        chill) should_notify=0 ;;
      esac
    fi
  fi

  if (( should_notify )); then
    send_notification "$usage" "$threshold"
    play_alert_sound
    last_alert=$now
  fi

  [[ "$new_state" == "OK" ]] && last_alert=0
  printf '%s\n%s\n' "$new_state" "$last_alert" > "$STATE_FILE"
}

cmd_set() {
  local key="${1:-}" value="${2:-}"
  case "$key" in
    threshold)
      if [[ ! "$value" =~ ^[0-9]+$ ]] || (( value < 1 || value > 99 )); then
        echo "error: threshold must be an integer 1-99" >&2
        exit 1
      fi
      write_config THRESHOLD "$value"
      echo "Threshold set to ${value}%"
      ;;
    delay)
      if [[ ! "$value" =~ ^[0-9]+$ ]] || (( value < 1 || value > 59 )); then
        echo "error: delay must be an integer 1-59 (minutes)" >&2
        exit 1
      fi
      write_config DELAY_MINUTES "$value"
      echo "Delay set to ${value} minute(s)."
      if is_installed; then
        update_scheduler
        echo "$(scheduler_name) entry updated."
      fi
      ;;
    behaviour)
      case "$value" in
        annoying|casual|chill) ;;
        *)
          echo "error: behaviour must be one of: annoying, casual, chill" >&2
          exit 1
          ;;
      esac
      write_config BEHAVIOUR "$value"
      echo "$(behaviour_emoji "$value") Behaviour set to ${value}"
      ;;
    "")
      echo "error: missing key. Valid keys: threshold, delay, behaviour" >&2
      exit 1
      ;;
    *)
      echo "error: unknown key '$key'. Valid keys: threshold, delay, behaviour" >&2
      exit 1
      ;;
  esac
}

cmd_get() {
  local key="${1:-}" b
  b=$(get_behaviour)
  case "$key" in
    ""|all)
      printf 'threshold: %s%%\ndelay:     %s min\nbehaviour: %s %s\n' \
             "$(get_threshold)" "$(get_delay)" "$(behaviour_emoji "$b")" "$b"
      ;;
    threshold) printf '%s%%\n' "$(get_threshold)" ;;
    delay)     printf '%s min\n' "$(get_delay)" ;;
    behaviour) printf '%s %s\n' "$(behaviour_emoji "$b")" "$b" ;;
    *) echo "error: unknown key '$key'. Valid keys: threshold, delay, behaviour" >&2; exit 1 ;;
  esac
}

cmd_status() {
  local threshold delay behaviour usage state line
  threshold=$(get_threshold)
  delay=$(get_delay)
  behaviour=$(get_behaviour)
  usage=$(read_usage)
  state="OK"
  if [[ -f "$STATE_FILE" ]]; then
    IFS= read -r line < "$STATE_FILE" && state="$line" || true
  fi
  printf 'os:        %s\nscheduler: %s\nusage:     %s%%\nthreshold: %s%%\ndelay:     %s min\nbehaviour: %s %s\nstate:     %s\n' \
         "$JOJO_OS" "$(scheduler_name)" "$usage" "$threshold" "$delay" \
         "$(behaviour_emoji "$behaviour")" "$behaviour" "$state"
}

cmd_install() {
  local src src_dir
  src="$(resolve_path "$0")"
  src_dir="$(dirname "$src")"

  mkdir -p "$INSTALL_DIR"

  if [[ "$src" != "$INSTALL_PATH" ]]; then
    cp "$src" "$INSTALL_PATH"
    chmod +x "$INSTALL_PATH"
    echo "Installed: $INSTALL_PATH"
  fi

  if [[ -f "$src_dir/$SOUND_FILE" ]]; then
    mkdir -p "$DATA_DIR"
    cp "$src_dir/$SOUND_FILE" "$DATA_DIR/$SOUND_FILE"
    echo "Installed alert sound: $DATA_DIR/$SOUND_FILE"
  fi

  update_scheduler
  echo "$(scheduler_name) scheduled to run every $(get_delay) minute(s)."

  case ":$PATH:" in
    *":$INSTALL_DIR:"*) ;;
    *)
      echo ""
      echo "NOTE: $INSTALL_DIR is not on your PATH."
      echo "Add this line to your shell profile (~/.bashrc or ~/.zshrc):"
      echo "  export PATH=\"\$HOME/.local/bin:\$PATH\""
      echo "Then restart your shell."
      ;;
  esac

  echo ""
  echo "Done. Try: jojo status"
}

cmd_uninstall() {
  remove_scheduler
  rm -f "$INSTALL_PATH"
  rm -f "$STATE_FILE"
  rm -rf "$DATA_DIR"
  echo "Uninstalled jojo."
}

cmd_help() {
  cat <<EOF
jojo — RAM threshold monitor with desktop notifications (Linux & macOS)

Usage: jojo [command] [args]

Commands:
  check                    Run the threshold check (default; called by scheduler)
  set threshold <percent>  Persist threshold (1-99). Example: jojo set threshold 80
  set delay <minutes>      Persist check interval (1-59). Example: jojo set delay 5
  set behaviour <mode>     annoying 🚨 | casual 🙂 | chill 😎
  get [key]                Print a value (threshold|delay|behaviour) or all if omitted
  status                   Print os, scheduler, usage, threshold, delay, behaviour, state
  install                  Install to ~/.local/bin and register with the scheduler
  uninstall                Reverse install
  help                     Show this message

Scheduler:
  Linux → cron, macOS → launchd (chosen automatically)

Environment:
  RAM_THRESHOLD            One-off override; takes precedence over the persisted threshold
EOF
}

case "${1:-check}" in
  check)           cmd_check ;;
  set)             shift; cmd_set "${1:-}" "${2:-}" ;;
  get)             shift; cmd_get "${1:-}" ;;
  status)          cmd_status ;;
  install)         cmd_install ;;
  uninstall)       cmd_uninstall ;;
  help|-h|--help)  cmd_help ;;
  *) echo "unknown command: $1" >&2; echo "" >&2; cmd_help >&2; exit 1 ;;
esac
